rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hanya user terautentikasi (login). Tidak ada register di app.
    function signedIn() {
      return request.auth != null;
    }

    match /schedulePlans/{planId} {
      allow read, write: if signedIn();
    }

    match /feedHistory/{id} {
      allow read, write: if signedIn();
    }

    // Data Info Tugas Akhir (judul, mahasiswa, dosen pembimbing).
    match /siteContent/{docId} {
      allow read, write: if signedIn();
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // default: tolak
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
